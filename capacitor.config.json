{
    "appId": "com.fontstudio.app",
    "appName": "فونت ستوديو",
    "webDir": "www",
    "bundledWebRuntime": false,
    "server": {
        "androidScheme": "https"
    },
    "plugins": {
        "SplashScreen": {
            "launchShowDuration": 2000,
            "backgroundColor": "#6c5ce7",
            "showSpinner": false
        },
        "Keyboard": {
            "resize": "body",
            "resizeOnFullScreen": true
        }
    },
    "android": {
        "allowMixedContent": true,
        "captureInput": true,
        "webContentsDebuggingEnabled": false
    }
}
